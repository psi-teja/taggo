# Required: IP address of the host machine (used for CORS and ALLOWED_HOSTS)
HOST_IP=192.168.1.100

# Required: Full PostgreSQL connection string
DATABASE_URL=postgres://admin:yourpassword@db:5432/taggo

# Required: Secret key for Django cryptographic signing (generate a strong random value for production)
SECRET_KEY=change-me-to-a-long-random-string

# Required: Postgres credentials (must match DATABASE_URL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=taggo

# Optional: Set to True for development, False for production
DEBUG=False

# Optional: Override default media storage path
# MEDIA_ROOT=/path/to/media
